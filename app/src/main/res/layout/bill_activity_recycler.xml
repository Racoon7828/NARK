<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="16dp"
    android:paddingBottom="16dp"
    android:background="#FFFFFF">

    <TextView
        android:id="@+id/bill_activity_rname"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="의안명"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#1a1a2e"
        android:lineSpacingExtra="4dp" />

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" android:layout_marginTop="12dp" android:layout_marginBottom="12dp" />

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingTop="6dp" android:paddingBottom="6dp">
        <TextView android:layout_width="110dp" android:layout_height="wrap_content" android:text="의안번호" android:textSize="13sp" android:textColor="#555555" android:textStyle="bold" />
        <TextView android:id="@+id/bill_activity_num" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textSize="14sp" android:textColor="#1a1a2e" />
    </LinearLayout>
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" />

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingTop="6dp" android:paddingBottom="6dp">
        <TextView android:layout_width="110dp" android:layout_height="wrap_content" android:text="제안일" android:textSize="13sp" android:textColor="#555555" android:textStyle="bold" />
        <TextView android:id="@+id/bill_activity_date" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textSize="14sp" android:textColor="#1a1a2e" />
    </LinearLayout>
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" />

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingTop="6dp" android:paddingBottom="6dp">
        <TextView android:layout_width="110dp" android:layout_height="wrap_content" android:text="제안자" android:textSize="13sp" android:textColor="#555555" android:textStyle="bold" />
        <TextView android:id="@+id/bill_activity_prp" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textSize="14sp" android:textColor="#1a1a2e" />
    </LinearLayout>
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" />

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingTop="6dp" android:paddingBottom="6dp">
        <TextView android:layout_width="110dp" android:layout_height="wrap_content" android:text="제안자 구분" android:textSize="13sp" android:textColor="#555555" android:textStyle="bold" />
        <TextView android:id="@+id/bill_activity_prpsep" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textSize="14sp" android:textColor="#1a1a2e" />
    </LinearLayout>
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" />

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingTop="6dp" android:paddingBottom="6dp">
        <TextView android:layout_width="110dp" android:layout_height="wrap_content" android:text="소관위" android:textSize="13sp" android:textColor="#555555" android:textStyle="bold" />
        <TextView android:id="@+id/bill_activity_RA" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textSize="14sp" android:textColor="#1a1a2e" />
    </LinearLayout>
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" />

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingTop="6dp" android:paddingBottom="6dp">
        <TextView android:layout_width="110dp" android:layout_height="wrap_content" android:text="대" android:textSize="13sp" android:textColor="#555555" android:textStyle="bold" />
        <TextView android:id="@+id/bill_activity_dae" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textSize="14sp" android:textColor="#1a1a2e" />
    </LinearLayout>
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" />

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingTop="6dp" android:paddingBottom="6dp">
        <TextView android:layout_width="110dp" android:layout_height="wrap_content" android:text="위원회 회부일" android:textSize="13sp" android:textColor="#555555" android:textStyle="bold" />
        <TextView android:id="@+id/bill_activity_CRD" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textSize="14sp" android:textColor="#1a1a2e" />
    </LinearLayout>
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" />

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingTop="6dp" android:paddingBottom="6dp">
        <TextView android:layout_width="110dp" android:layout_height="wrap_content" android:text="처리결과" android:textSize="13sp" android:textColor="#555555" android:textStyle="bold" />
        <TextView android:id="@+id/bill_activity_proResult" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textSize="14sp" android:textColor="#1a1a2e" />
    </LinearLayout>
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" />

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingTop="6dp" android:paddingBottom="6dp">
        <TextView android:layout_width="110dp" android:layout_height="wrap_content" android:text="처리일" android:textSize="13sp" android:textColor="#555555" android:textStyle="bold" />
        <TextView android:id="@+id/bill_activity_proDate" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textSize="14sp" android:textColor="#1a1a2e" />
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" android:layout_marginTop="12dp" android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/bill_activity_btn"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/round_button_for_bill"
        android:text="세부 사항 바로가기"
        android:textColor="#FFFFFF"
        android:textSize="14sp" />

</LinearLayout>
